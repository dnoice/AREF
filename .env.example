# ============================================================================
# AREF Platform — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are optional — sensible defaults are used when unset.
# ============================================================================

# --- General ---
AREF_ENVIRONMENT=development        # "docker" for container hostnames, else localhost
AREF_DEBUG=true
AREF_LOG_LEVEL=INFO
AREF_RISK_PROFILE=balanced          # balanced | availability_critical | data_integrity_critical | innovation_heavy
AREF_API_HOST=0.0.0.0
AREF_API_PORT=8000
AREF_DASHBOARD_PORT=8080

# --- Database (provisioned, not yet active) ---
AREF_DB_HOST=localhost
AREF_DB_PORT=5432
AREF_DB_NAME=aref
AREF_DB_USER=aref
AREF_DB_PASSWORD=aref_secret

# --- Redis (provisioned, not yet active) ---
AREF_REDIS_HOST=localhost
AREF_REDIS_PORT=6379
AREF_REDIS_DB=0
# AREF_REDIS_PASSWORD=

# --- Detection (Pillar I) ---
AREF_DETECTION_MTTD_TARGET_SECONDS=300          # < 5 minutes
AREF_DETECTION_THRESHOLD_CHECK_INTERVAL=10
AREF_DETECTION_ANOMALY_CHECK_INTERVAL=30
AREF_DETECTION_SYNTHETIC_PROBE_INTERVAL=15
AREF_DETECTION_CHANGE_CORRELATION_WINDOW=600
AREF_DETECTION_ALERT_FATIGUE_MAX_PER_WEEK=50
AREF_DETECTION_ALERT_TO_ACTION_RATIO=3.0

# --- Absorption (Pillar II) ---
AREF_ABSORPTION_BLAST_RADIUS_TARGET_PCT=95
AREF_ABSORPTION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AREF_ABSORPTION_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
AREF_ABSORPTION_CIRCUIT_BREAKER_HALF_OPEN_MAX=3
AREF_ABSORPTION_BULKHEAD_MAX_CONCURRENT=50
AREF_ABSORPTION_RATE_LIMIT_REQUESTS_PER_SECOND=100
AREF_ABSORPTION_RATE_LIMIT_BURST=20

# --- Adaptation (Pillar III) ---
AREF_ADAPTATION_LATENCY_TARGET_SECONDS=30
AREF_ADAPTATION_SCALE_UP_CPU_THRESHOLD=80
AREF_ADAPTATION_SCALE_DOWN_CPU_THRESHOLD=30
AREF_ADAPTATION_TRAFFIC_SHIFT_HEALTH_THRESHOLD=0.7
AREF_ADAPTATION_FEATURE_FLAG_ERROR_BUDGET_TRIGGER=0.5
AREF_ADAPTATION_ADAPTATION_WINDOW_SECONDS=120

# --- Recovery (Pillar IV) ---
AREF_RECOVERY_MTTR_TARGET_SECONDS=900            # < 15 minutes
AREF_RECOVERY_T0_TARGET_SECONDS=300               # 0-5 min
AREF_RECOVERY_T1_TARGET_SECONDS=900               # 5-15 min
AREF_RECOVERY_T2_TARGET_SECONDS=3600              # 15-60 min
AREF_RECOVERY_T3_TARGET_SECONDS=14400             # 1-4 hours
AREF_RECOVERY_T4_TARGET_DAYS=14                   # 1-2 weeks
AREF_RECOVERY_RUNBOOK_DRILL_INTERVAL_DAYS=90

# --- Evolution (Pillar V) ---
AREF_EVOLUTION_IMPROVEMENT_VELOCITY_TARGET=8      # > 8 actions/quarter
AREF_EVOLUTION_ACTION_COMPLETION_RATE_TARGET=85    # > 85%
AREF_EVOLUTION_RECURRENCE_RATE_TARGET=10           # < 10%
AREF_EVOLUTION_KNOWLEDGE_SHARE_TARGET_HOURS=72
AREF_EVOLUTION_POST_INCIDENT_REVIEW_DEADLINE_HOURS=72

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=aref
